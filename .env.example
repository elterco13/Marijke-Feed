# === Aquarium Science Monitor — Environment Configuration ===
# Copy this file to .env and fill in your values.

# --- Contact / Identification ---
# Used in HTTP User-Agent and API polite-pool headers (required for OpenAlex)
OPENALEX_EMAIL=your_email@example.com
CONTACT_EMAIL=your_email@example.com

# --- Database ---
DATABASE_URL=sqlite:///./data/app.db

# --- Request Settings ---
REQUEST_TIMEOUT=30
USER_AGENT=AquariumScienceMonitor/1.0 (mailto:your_email@example.com)

# --- Defaults ---
DEFAULT_RESULT_LIMIT=50
DEFAULT_DATE_WINDOW_DAYS=30

# --- Connector Toggles (true/false) ---
ENABLE_CONNECTOR_OPENALEX=true
ENABLE_CONNECTOR_CROSSREF=true
ENABLE_CONNECTOR_EUROPEPMC=true
ENABLE_CONNECTOR_PUBMED=true
ENABLE_CONNECTOR_RSS=true
ENABLE_CONNECTOR_NEWS=false

# --- PubMed (optional, increases rate limit) ---
# PUBMED_API_KEY=your_pubmed_api_key_here

# --- Log Level ---
LOG_LEVEL=INFO
